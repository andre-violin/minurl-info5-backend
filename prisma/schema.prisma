generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Plan {
  id        String   @id @default(uuid())
  name      String
  price     Decimal @db.Decimal(10, 2)
  maxLinks  Int     @map("max_links")
  maxClicks Int    @map("max_clicks")
  users     User[]
  @@map("plans")
}

model User {
  id           String     @id
  email        String     @unique
  createdAt    DateTime   @default(now()) @map("created_at")
  planId       String?    @unique @map("plan_id")
  plan         Plan?      @relation(fields: [planId], references: [id])
  shortLinks   ShortLink[]
  reports      Report[]
  @@map("users")
}

model ShortLink {
  id          String   @id @default(uuid())
  userId      String      @map("user_id")
  originalUrl String      @map("original_url")
  shortCode   String      @unique @map("short_code")
  createdAt   DateTime    @default(now()) @map("created_at")
  user        User        @relation(fields: [userId], references: [id])
  clickTracks ClickTrack[]
  @@map("short_links")
}

model ClickTrack {
  id           String   @id @default(uuid())
  shortLinkId  String    @map("short_link_id")
  clickedAt    DateTime  @default(now()) @map("clicked_at")
  referrer     String?
  userAgent    String?   @map("user_agent")
  shortLink    ShortLink @relation(fields: [shortLinkId], references: [id])
  @@map("click_tracking")
}

model Report {
  id           String   @id @default(uuid())
  userId       String    @map("user_id")
  reportType   String   @map("report_type")
  generatedAt  DateTime @default(now()) @map("generated_at")
  data         Json?
  user         User     @relation(fields: [userId], references: [id])
  @@map("reports")
}
